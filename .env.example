# ============================================================
# .env (통합본 + PHASE 3 최종 — 서버 배포용 실제 값 반영)
# 이 파일은 .env 예시 템플릿입니다. 복사해 .env 로 만들고 실제 값을 채우세요.
# (실제 .env 는 절대 git/공유 zip 에 올리지 마세요.)
# ============================================================

# --- OpenAI ---
OPENAI_API_KEY=

# --- Oracle Autonomous DB ---
DB_USER=
DB_PASSWORD=
DB_DSN=
WALLET_DIR=
WALLET_PASSWORD=

# --- ChromaDB (Client-Server 모드, 포트 8001) ---
CHROMA_HOST=localhost
CHROMA_PORT=8001

# --- CORS ---
ALLOWED_ORIGINS=

# --- 관리자 색인 동기화 인증 키 ---
ADMIN_KEY=

# ── [PHASE 1-⑥] LangSmith 모니터링 ──────────────────────────────────
# LANGSMITH_API_KEY 발급 후 true 로 변경
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=shoppingmall-ai

# ── [PHASE 1-⑥] 동적 모델 선택 ──────────────────────────────────────
# true: SIMPLE(인사/잡담)은 저비용 모델(get_intent_llm), 나머지는 고품질 모델 유지
DYNAMIC_MODEL_SELECTION=true

# ── [PHASE 1-⑦] 멀티 모델 추상화 ────────────────────────────────────
# 벤치마크 시: LLM_PROVIDER=openai / gemini / anthropic / deepseek 로 전환
LLM_PROVIDER=openai
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
# [PHASE 3] DeepSeek 신규 — API 키 발급: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# ── [PHASE 1-⑧] RAG 재랭킹 ──────────────────────────────────────────
# COHERE_API_KEY 없으면 원본 순서 유지로 자동 폴백 (서버 안 멈춤)
RERANK_ENABLED=true
RERANK_PROVIDER=cohere
COHERE_API_KEY=
COHERE_RERANK_MODEL=rerank-v3.5
RERANK_CANDIDATES=10
RERANK_TOP_N=4

# ── [PHASE 1-⑨] MCP 외부 서비스 연동 ────────────────────────────────
MCP_ENABLED=true
MCP_CONFIG_PATH=mcp_config.json

# ── [PHASE 2-①] 멀티모달 OpenCLIP ───────────────────────────────────
# false 유지: ARM 호환성 미검증 + IMAGE_URL 아직 NULL
# 이미지 등록 완료 후 true 로 변경 + index_products_image 실행
CLIP_SERVING_ENABLED=true
CLIP_MODEL_NAME=ViT-B-32
CLIP_PRETRAINED=openai
CLIP_IMAGE_COLLECTION=products_image

# ── [PHASE 2-②] 개인화 추천 레벨 2 ─────────────────────────────────
PERSONALIZATION_ENABLED=true
PERSONALIZATION_ALPHA=0.7
PERSONALIZATION_BETA=0.3
PERSONALIZATION_RECENCY_HALFLIFE_DAYS=90
PERSONALIZATION_CACHE_TTL=300
PERSONALIZATION_MAX_HISTORY=50
# 취향 벡터 캐시 항목 상한(메모리 보호). 상한 도달 시 만료분→가장 오래된 순으로 축출.
PERSONALIZATION_CACHE_MAX=512

# ── [PHASE 3-①] Redis 체크포인터 ────────────────────────────────────
# Redis Stack 설치 후 활성화 (비워두면 MemorySaver 폴백)
REDIS_URL=

# ── [PHASE 3-②] 성능/비용 비교 측정 ────────────────────────────────
METRICS_ENABLED=true
METRICS_LOG_PATH=metrics.jsonl
# 모델 단가 오버라이드 (실단가로 갱신 필요 시 주석 해제)
# PRICE_OPENAI_GPT_5_4_INPUT=0.005
# PRICE_OPENAI_GPT_5_4_OUTPUT=0.015
# PRICE_GEMINI_GEMINI_3_1_FLASH_INPUT=0.000075
# PRICE_GEMINI_GEMINI_3_1_FLASH_OUTPUT=0.0003
# PRICE_DEEPSEEK_DEEPSEEK_V4_FLASH_INPUT=0.00014
# PRICE_DEEPSEEK_DEEPSEEK_V4_FLASH_OUTPUT=0.00028

# ── [개선] LLM 호출 타임아웃 (초) ───────────────────────────────────
# OpenAI/Gemini/Anthropic/DeepSeek 모든 LLM HTTP 요청에 적용. 무한 대기 방지.
# 0 또는 빈 값/오류 시 무제한(기존 동작). 라우터/Agent/RAG/환각재시도 공통.
LLM_TIMEOUT=30

# ── [멀티턴] 이력 트리밍 (컨텍스트 윈도우 초과 방지) ─────────────────
# LLM 에 넘길 최대 메시지 개수. 누적 대화가 길어져도 입력은 최근 N개로 제한한다.
# (Checkpointer 원본은 보존 — LLM 입력만 트리밍). 0 이하/오류면 20 폴백.
# 대략 20개 = 질문/답변 10턴. 맥락을 더 길게 유지하려면 키운다.
HISTORY_MAX_MESSAGES=20

# ── [개선] Oracle 커넥션 풀 ─────────────────────────────────────────
# 매 요청 새 커넥션 → 풀 재사용으로 전환(동시요청 안정화). 풀 생성 실패 시
# 자동으로 기존 직접연결 방식 폴백(회귀 없음). ARM 2 OCPU 기준 보수적 기본값.
ORACLE_POOL_MIN=2
ORACLE_POOL_MAX=10
ORACLE_POOL_INCREMENT=1

# ── [하이브리드 검색] BM25 (Sparse) + 벡터 (Dense) Fusion ────────────
# true 면 SEMANTIC 검색에서 벡터 후보 + BM25 키워드 후보를 병합한다.
# false(기본)면 BM25 경로를 타지 않아 기존 동작과 100% 동일.
# 권장: RERANK_ENABLED=true 와 함께 켜서 Cohere 로 최종 재정렬.
BM25_ENABLED=true
# 한국어 부분 매칭용 문자 n-gram 크기(기본 2)
BM25_NGRAM=2
# RRF(Reciprocal Rank Fusion) 상수 k. Dense/Sparse 후보를 '순위'만으로 융합할 때 쓴다
# (절대 점수 스케일 차이로 인한 융합 편향 방지). 원논문 기본값 60. 미설정/0/오류 시 60.
RRF_K=60

# ── [대규모 청크 처리] 긴 상품 설명 Context-Rich Chunking ─────────────
# 임베딩 대상 텍스트가 이 글자 수를 넘으면 청크로 분할해 각 청크 앞에
# "[상품명 | 카테고리]" 프리픽스를 삽입한 뒤 색인한다(RecursiveCharacterTextSplitter).
# 현재 카탈로그(상품 설명 200~250자)는 전부 이 임계값 이하라 청킹 코드 경로가
# 실제로는 안 타는 "대비용" 설정이다 — 미설정/오류 시 500/50 폴백.
CHUNK_THRESHOLD_CHARS=500
CHUNK_OVERLAP_CHARS=50

# ── [Human-in-the-loop] 환불 신청 관리자 알림 ─────────────────────────
# 셋 다 있어야 발송(하나라도 비어있으면 생략, best-effort). Gmail 앱 비밀번호 필요
# (Spring Boot MAIL_USERNAME/MAIL_PASSWORD와 같은 계정 재사용 가능).
ADMIN_ALERT_EMAIL=
MAIL_USERNAME=
MAIL_PASSWORD=

# Slack 알림(선택) — MCP_ENABLED=true + mcp_config.json 의 slack 서버 등록 필요.
# 비어있으면 발송 생략(best-effort). 서버 실행 시 SLACK_MCP_ADD_MESSAGE_TOOL 에
# 이 채널ID 를 포함해야 실제 전송이 허용된다(mcp_config.json.example 참고).
SLACK_REFUND_CHANNEL_ID=

# Gmail 알림과 별도 채널(Slack MCP). 비어있으면 생략(best-effort).
# MCP_ENABLED=true + mcp_config.json 에 slack 서버(conversations_add_message 도구,
# korotovsky/slack-mcp-server 등)가 등록돼 있어야 실제 발송된다.
SLACK_MCP_REFUND_CHANNEL_ID=
